# Required
ANTHROPIC_API_KEY=sk-ant-...

# Google Sheets output
# Create a service account at console.cloud.google.com → IAM → Service Accounts
# Download JSON key and paste the path here
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Name for the Google Sheet that will be created/reused
GOOGLE_SHEET_NAME=Wayground Content Evaluation - Batch 2

# Optional: share the sheet with this email (edit access)
SHARE_EMAIL=chandan@quizizz.com

# Webflow (leave blank until credentials are ready)
WEBFLOW_API_TOKEN=
WEBFLOW_SITE_ID=
# Collection IDs per cluster (fill in after running: python orchestrator.py webflow-setup)
WEBFLOW_COLLECTION_DIFFERENTIATED_LEARNING=
WEBFLOW_COLLECTION_SCAFFOLDING=
WEBFLOW_COLLECTION_ENGAGEMENT=
