# Path to the shared Quizizz credentials folder
SHARED_CREDS_DIR=/Users/YOUR_USERNAME/Desktop/checking_claude/projects_mvps/_shared_creds/quizizz

# OAuth redirect URI (must match GCP Console exactly)
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Required for local dev (non-HTTPS OAuth)
OAUTHLIB_INSECURE_TRANSPORT=1
